{
  "name": "context-ferry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @context-ferry/shared build && pnpm --filter @context-ferry/server build && pnpm --filter @context-ferry/extension build",
    "check-against": "pnpm --filter @context-ferry/extension check-against",
    "check-reddit": "pnpm --filter @context-ferry/extension check-against -- --cases=../../checks/reddit-cases.json",
    "check-twitter": "pnpm --filter @context-ferry/extension check-against -- --cases=../../checks/twitter-cases.json",
    "dev:server": "pnpm --filter @context-ferry/server dev",
    "dev:server:pages": "cross-env PUBLISH_MODE=github-pages GITHUB_PAGES_BASE_URL=https://liux4989.github.io/ContextFerry pnpm --filter @context-ferry/server dev",
    "dev:server:gDrive": "dotenv -e ./.env.google-drive -- cross-env PUBLISH_MODE=google-drive pnpm --filter @context-ferry/server dev",
    "typecheck": "pnpm --filter @context-ferry/shared typecheck && pnpm --filter @context-ferry/server typecheck && pnpm --filter @context-ferry/extension typecheck"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.4.2",
    "typescript": "^5.9.3"
  }
}
